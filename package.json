{
  "name": "@theyahia/cdek-mcp",
  "version": "2.0.0",
  "description": "MCP server for CDEK delivery API — 14 tools: tariff calculation, order management, tracking, cities, regions, delivery points, courier pickup, barcode/receipt printing, webhooks. OAuth2 token management with retry and rate limit handling.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cdek-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/cdek-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "cdek",
    "delivery",
    "shipping",
    "logistics",
    "tracking",
    "courier",
    "barcode",
    "webhook"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/cdek-mcp.git"
  },
  "homepage": "https://github.com/theYahia/cdek-mcp#readme",
  "author": "Yahia"
}
